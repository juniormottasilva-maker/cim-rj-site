{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "cim-rj-site (static)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", ".", "-l", "3000"],
      "port": 3000
    },
    {
      "name": "n8n (automação)",
      "runtimeExecutable": "docker-compose",
      "runtimeArgs": ["-f", "infra/n8n/docker-compose.yml", "up", "n8n"],
      "port": 5678
    },
    {
      "name": "uptime-kuma (monitoramento)",
      "runtimeExecutable": "docker-compose",
      "runtimeArgs": ["-f", "infra/n8n/docker-compose.yml", "up", "uptime-kuma"],
      "port": 3001
    }
  ]
}
